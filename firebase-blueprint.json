{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A COBOL modernization project.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project description" },
        "targetLanguage": { "type": "string", "enum": ["Python", "Java", "C", "C#", "C++"], "description": "Target language for conversion" },
        "createdBy": { "type": "string", "description": "User ID of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "targetLanguage", "createdBy", "createdAt"]
    },
    "SourceElement": {
      "title": "SourceElement",
      "description": "A COBOL source file or element within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the parent project" },
        "name": { "type": "string", "description": "Element name (e.g., PAYROLL.CBL)" },
        "content": { "type": "string", "description": "COBOL source code content" },
        "convertedContent": { "type": "string", "description": "Generated target code content" },
        "targetLanguage": { "type": "string", "description": "Target language used for this element" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Completed", "Failed"], "description": "Conversion status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["projectId", "name", "content", "status", "createdAt"]
    },
    "InputFile": {
      "title": "InputFile",
      "description": "An input data file associated with a source element.",
      "type": "object",
      "properties": {
        "elementId": { "type": "string", "description": "ID of the source element" },
        "name": { "type": "string", "description": "File name" },
        "path": { "type": "string", "description": "Path in the repository" },
        "content": { "type": "string", "description": "File content or metadata" }
      },
      "required": ["elementId", "name", "path"]
    },
    "OutputFile": {
      "title": "OutputFile",
      "description": "An output data file generated by the source or destination code.",
      "type": "object",
      "properties": {
        "elementId": { "type": "string", "description": "ID of the source element" },
        "type": { "type": "string", "enum": ["COBOL", "Destination"], "description": "Type of output" },
        "name": { "type": "string", "description": "File name" },
        "path": { "type": "string", "description": "Path in the repository" },
        "content": { "type": "string", "description": "File content" }
      },
      "required": ["elementId", "type", "name", "path"]
    },
    "ConversionReport": {
      "title": "ConversionReport",
      "description": "A report summarizing the conversion results for an element.",
      "type": "object",
      "properties": {
        "elementId": { "type": "string", "description": "ID of the source element" },
        "totalLines": { "type": "integer", "description": "Total lines of COBOL code" },
        "convertedLines": { "type": "integer", "description": "Number of lines successfully converted" },
        "errors": { "type": "array", "items": { "type": "string" }, "description": "List of conversion errors" },
        "warnings": { "type": "array", "items": { "type": "string" }, "description": "List of conversion warnings" },
        "unsupportedStatements": { "type": "array", "items": { "type": "string" }, "description": "List of unsupported COBOL statements" }
      },
      "required": ["elementId", "totalLines", "convertedLines"]
    },
    "TestCase": {
      "title": "TestCase",
      "description": "A unit test case for a source element.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the parent project" },
        "elementId": { "type": "string", "description": "ID of the source element" },
        "name": { "type": "string", "description": "Test case name" },
        "input": { "type": "string", "description": "Input data for the test" },
        "expectedOutput": { "type": "string", "description": "Expected output data" }
      },
      "required": ["projectId", "elementId", "name", "input", "expectedOutput"]
    },
    "ExecutionResult": {
      "title": "ExecutionResult",
      "description": "The result of executing a test case.",
      "type": "object",
      "properties": {
        "testCaseId": { "type": "string", "description": "ID of the test case" },
        "type": { "type": "string", "enum": ["COBOL", "Destination"], "description": "Type of execution" },
        "actualOutput": { "type": "string", "description": "Actual output data" },
        "status": { "type": "string", "enum": ["Pass", "Fail"], "description": "Test status" },
        "executedAt": { "type": "string", "format": "date-time", "description": "Execution timestamp" }
      },
      "required": ["testCaseId", "type", "actualOutput", "status", "executedAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of modernization projects."
    },
    "/projects/{projectId}/elements/{elementId}": {
      "schema": "SourceElement",
      "description": "Source elements within a project."
    },
    "/projects/{projectId}/elements/{elementId}/inputFiles/{fileId}": {
      "schema": "InputFile",
      "description": "Input files for a source element."
    },
    "/projects/{projectId}/elements/{elementId}/outputFiles/{fileId}": {
      "schema": "OutputFile",
      "description": "Output files generated for a source element."
    },
    "/projects/{projectId}/elements/{elementId}/reports/{reportId}": {
      "schema": "ConversionReport",
      "description": "Conversion reports for a source element."
    },
    "/projects/{projectId}/testCases/{testCaseId}": {
      "schema": "TestCase",
      "description": "Test cases for a project."
    },
    "/projects/{projectId}/testCases/{testCaseId}/results/{resultId}": {
      "schema": "ExecutionResult",
      "description": "Execution results for a test case."
    }
  }
}
