{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug App Server (tsx)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect",
        "--import",
        "tsx",
        "server.ts"
      ],
      "env": {
        "NODE_ENV": "development",
        "DISABLE_HMR": "true"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
